<%- include("partials/header") %> <%- include("partials/alert") %>
<div class="container alert alert-warning mt-4" role="alert">
  ⚠️ This is a small demo project. All CRUD functions are visible here to showcase how to develop and run a CRUD system. In a real application, these buttons would not be exposed like this.
</div>
<div class="container mt-4">
    <h1>Books I’ve read</h1>
    <p>Tiny summary but detailed notes for each. Use the ISBN number to find it from your local library or anywhere else. This page will constantly update as I read more, so bookmark it if you want to check back in a few months.</p>
    <div class="d-flex">
        <a href="/add" class="btn btn-outline-success">Add New Book</a>
    </div>

    <% books.forEach(book => { %>
        <div class="card mt-4">
            <div class="row g-0 align-items-stretch">
                <div class="col-md-2">
                <img src="https://covers.openlibrary.org/b/isbn/<%= book.isbn %>-L.jpg"
                    class="img-fluid h-100 rounded-start object-fit-cover"
                    alt="<%= book.name %> Cover Picture">
                </div>
                <div class="col-md-10">
                    <div class="card-body">
                        <h5 class="card-title"><%= book.name %></h5>
                        <p class="card-text">ISBN: <%= book.isbn %></p>
                        <p class="card-text"><small class="text-body-secondary">Date Read: <%= book.date %></small></p>
                        <p class="card-text"><%= book.description %></p>
                        <div class="d-flex flex-column">
                            <div class="py-2">
                                <a href="/book/<%= book.id %>" class="btn btn-outline-success">See Notes</a>
                            </div>
                            <div class="py-2">
                                <a href="/edit/<%= book.id %>" class="btn btn-outline-primary">Edit</a>

                                <form action="/delete/<%= book.id %>" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% }); %>
</div>

<%- include("partials/footer.ejs") %>